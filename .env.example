# ── Metasploit RPC Backend ──────────────────────────────────
MSF_RPC_HOST=127.0.0.1
MSF_RPC_PORT=55553
MSF_RPC_SSL=false
MSF_RPC_USER=msf
MSF_RPC_PASSWORD=changeme

# Set to "true" to use demo data when RPC is unreachable
MSF_DEMO_MODE=true

# ── Dashboard API Auth ────────────────────────────────────
# Required in production — sent as Bearer token or X-API-Key header
DASHBOARD_API_KEY=generate-a-long-random-secret-here

# ── Docker / Caddy Reverse Proxy ──────────────────────────
# Domain for Caddy (auto-TLS). Leave as localhost for dev
CADDY_DOMAIN=localhost

# Basic auth credentials at the Caddy proxy level
CADDY_AUTH_USER=admin
CADDY_AUTH_PASS=changeme-this-password
